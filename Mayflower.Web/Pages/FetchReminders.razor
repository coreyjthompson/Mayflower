@page "/reminders"
@page "/reminders/{AccountId?}"

@using Mayflower.Core.Infrastructure.Queries;
@using Mayflower.Core.Infrastructure.Queries.Reminders;
@using Mayflower.Core.Infrastructure.Interfaces.Queries;
@using Mayflower.Core.Extensions;

@inject IQueryProcessor _queries
@inject NavigationManager _navigationManager


<PageTitle>Reminders</PageTitle>
<div>
    <header class="d-flex mb-3">
        <div class="flex-fill text-start align-middle"><h1>Reminders</h1></div>
        <div class="flex-fill text-end align-middle">
            <Dropdown>
                <DropdownToggleButton Color="ButtonColor.Primary" Size="Size.Large">Add</DropdownToggleButton>
                <DropdownMenu>
                    <DropdownItem To="#" Type="ButtonType.Link">Bill</DropdownItem>
                    <DropdownItem To="#" Type="ButtonType.Link">Income</DropdownItem>
                    <DropdownItem To="#" Type="ButtonType.Link">Transfer</DropdownItem>
                </DropdownMenu>
            </Dropdown>
        </div>
    </header>
    <div>
        @if (ReminderRows == null)
        {
            <p><em>Loading...</em></p>
        }
        else
        {
            <div class="row mb-3">
                <div class="col-md-6 col-lg-5 col-xl-2 mb-3 mb-lg-0">
                    @if (Accounts == null)
                    {
                        <p class="px-3">
                            <em>Loading list of accounts...</em>
                        </p>
                    }
                    else
                    {
                        <select @onchange="HandleAccountChangeAsync" class="form-select">
                            <option value="">Select an account</option>
                            @foreach (var account in Accounts)
                            {
                                if (account.Id == GetConvertedAccountId())
                                {
                                    <option value="@account.Id" selected>@account.Nickname</option>
                                }
                                else
                                {
                                    <option value="@account.Id">@account.Nickname</option>
                                }
                            }
                        </select>
                    }
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(AccountId))
            {
                @if (!ReminderRows.Any())
                {
                    <div class="alert alert-warning" role="alert">
                        There are no reminders for this account
                    </div>
                }
                else
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th width="1%"></th>
                                <th class="text-start">Type</th>
                                <th class="text-start">Description</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ReminderRows.Any())
                            {
                                foreach (var row in ReminderRows)
                                {
                                    <tr>
                                        <td class="text-start align-top">
                                            <button type="button" class="btn btn-primary btn-sm" @onclick="() => HandleEditReminderButtonClick(row.Id)">Edit</button>
                                        </td>
                                        <td class="text-start">@row.ReminderTheme</td>
                                        <td class="text-start">@row.Description</td>
                                        <td class="text-end"><span class="@row.AmountCss">@row.AmountForDisplay</span></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                }
            }

            <Modal @ref="ReminderFormModal" Title="Edit Reminder" IsVerticallyCentered="true">
                <BodyTemplate>
                    <EditForm Model="@EditReminderForm" OnSubmit="@HandleReminderFormSubmitAsync" id="editReminderForm">
                        <input type="hidden" @bind="EditReminderForm.Id" />
                        <div class="row g-3 mb-3">
                            <div class="col form-floating">
                                <select @onchange="HandleThemeChange" class="form-select" id="reminderThemeSelect">
                                    <option value="">@EditReminderForm.ReminderThemePlaceholderText</option>
                                    @foreach (var day in ReminderStyles)
                                    {
                                        if (day.Item1 == EditReminderForm.ReminderTheme)
                                        {
                                            <option value="@day.Item2" selected>@day.Item3</option>
                                        }
                                        else
                                        {
                                            <option value="@day.Item2">@day.Item3</option>
                                        }
                                    }
                                </select>
                                <label for="reminderThemeSelect">@EditReminderForm.ReminderThemeLabelText</label>
                            </div>
                            <div class="col form-floating">
                                <input type="text" class="form-control" @bind="EditReminderForm.Description" id="reminderDescriptionInput" placeholder="@EditReminderForm.DescriptionPlaceholderText" />
                                <label for="reminderDescriptionInput">@EditReminderForm.DescriptionLabelText</label>
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col form-floating">
                                <CurrencyInput TValue="decimal" @bind-Value="@EditReminderForm.Amount" Placeholder="@EditReminderForm.AmountPlaceholderText" Locale="en-US" id="reminderAmountInput" />
                                <label for="reminderAmountInput">@EditReminderForm.AmountLabelText</label>
                            </div>
                            <div class="col form-floating">
                                <DateInput TValue="DateOnly" @bind-Value="@EditReminderForm.WhenBegins" Placeholder="@EditReminderForm.WhenBeginsPlaceholderText" id="reminderWhenBegins" />
                                <label for="reminderWhenBegins">@EditReminderForm.WhenBeginsLabelText</label>
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col form-floating">
                                <input type="text" class="form-control" @bind="EditReminderForm.RecurrenceInterval" id="reminderIntervalInput" placeholder="@EditReminderForm.RecurrenceIntervalPlaceholderText" />
                                <label for="reminderIntervalInput">@EditReminderForm.RecurrenceIntervalLabelText</label>
                            </div>
                            <div class="col form-floating">
                                <select @onchange="HandleDayOfMonthChange" class="form-select" id="reminderDayOfMonthToSelect">
                                    <option value="">@EditReminderForm.RecurrenceDayOfWeekPlaceholderText</option>
                                    @foreach (var day in DaysOfMonth)
                                    {
                                        if (day == EditReminderForm.RecurrenceDayOfMonth)
                                        {
                                            <option value="@day" selected>@day</option>
                                        }
                                        else
                                        {
                                            <option value="@day">@day</option>
                                        }
                                    }
                                </select>
                                <label for="reminderDayOfMonthToInput">@EditReminderForm.RecurrenceDayOfMonthLabelText</label>
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col form-floating">
                                <select @onchange="HandleDayOfWeekChange" class="form-select" id="reminderDayOfWeekSelect">
                                    <option value="">@EditReminderForm.RecurrenceDayOfWeekPlaceholderText</option>
                                    @foreach (var day in DaysOfWeek)
                                    {
                                        if (day.Item1 == EditReminderForm.RecurrenceDayOfWeek)
                                        {
                                            <option value="@day.Item2" selected>@day.Item3</option>
                                        }
                                        else
                                        {
                                            <option value="@day.Item2">@day.Item3</option>
                                        }
                                    }
                                </select>
                                <label for="reminderDayOfWeekSelect">@EditReminderForm.RecurrenceDayOfWeekLabelText</label>
                            </div>
                            <div class="col form-floating">
                                <select @onchange="HandlePositionChange" class="form-select" id="reminderTransactionFromSelect">
                                    <option value="">@EditReminderForm.RecurrenceOrdinalPlaceholderText</option>
                                    @foreach (var position in Positions)
                                    {
                                        if (position.Item1 == EditReminderForm.RecurrenceOrdinal)
                                        {
                                            <option value="@position.Item2" selected>@position.Item3</option>
                                        }
                                        else
                                        {
                                            <option value="@position.Item2">@position.Item3</option>
                                        }
                                    }
                                </select>
                                <label for="reminderOrdinalInput">@EditReminderForm.RecurrenceOrdinalLabelText</label>
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col form-floating">
                                <select @onchange="HandleTransactionFromAccountChange" class="form-select" id="reminderTransactionFromSelect">
                                    <option value="">@EditReminderForm.TransactionFromPlaceholderText</option>
                                    @if (Accounts != null && Accounts.Any())
                                    {
                                        @foreach (var account in Accounts)
                                        {
                                            if (account.Id == GetConvertedAccountId())
                                            {
                                                <option value="@account.Id" selected>@account.Nickname</option>
                                            }
                                            else
                                            {
                                                <option value="@account.Id">@account.Nickname</option>
                                            }
                                        }
                                    }
                                </select>
                                <label for="reminderTransactionFromSelect">@EditReminderForm.TransactionFromLabelText</label>
                            </div>
                            <div class="col form-floating">
                                <select @onchange="HandleTransactionToAccountChange" class="form-select" id="reminderTransactionToSelect">
                                    <option value="">@EditReminderForm.TransactionToPlaceholderText</option>
                                    @if (Accounts != null && Accounts.Any())
                                    {
                                        @foreach (var account in Accounts)
                                        {
                                            if (account.Id == @EditReminderForm.TransactionToAccountId)
                                            {
                                                <option value="@account.Id" selected>@account.Nickname</option>
                                            }
                                            else
                                            {
                                                <option value="@account.Id">@account.Nickname</option>
                                            }
                                        }
                                    }
                                </select>
                                <label for="reminderTransactionToSelect">@EditReminderForm.TransactionToLabelText</label>
                            </div>
                        </div>
                    </EditForm>
                </BodyTemplate>
                <FooterTemplate>
                    <Button Color="ButtonColor.Secondary" @onclick="HandleHideReminderModalClickAsync">Cancel</Button>
                    <Button Color="ButtonColor.Primary" Type="ButtonType.Submit" form="editOccurrenceForm">Save changes</Button>
                </FooterTemplate>
            </Modal>

        }
    </div>
</div>





