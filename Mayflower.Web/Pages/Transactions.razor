@page "/Transactions"
@inject TransactionService bankService

<PageTitle>Account Transactions</PageTitle>

<h1>Account Transactions</h1>

<p>This component demonstrates fetching data from a service.</p>

@if (transactions == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Time</th>
                <th>Amount</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            @if (transactions.Any())
            {
                foreach (var transaction in transactions)
                {
                    <tr>
                        <td>@transaction.Date.ToString("MM/dd/yyyy")</td>
                        <td>@transaction.Time.ToString("h:mm tt")</td>
                        <td>@transaction.Amount.ToString("#,##0.00")</td>
                        <td>@transaction.Description</td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private IList<Dto.Transaction>? transactions;

    protected override void OnInitialized()
    {
        transactions = bankService.GetTransactions();
    }
}
